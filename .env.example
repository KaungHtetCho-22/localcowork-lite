# LocalCowork Lite — Configuration
# Copy this to .env and adjust

# =============================================================
# Model Server (llama.cpp running locally)
# =============================================================
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen2.5-7b-instruct
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.1
LLM_MAX_TOKENS=1024

# =============================================================
# FastAPI Backend
# =============================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173

# =============================================================
# Knowledge Base (ChromaDB)
# =============================================================
CHROMA_PERSIST_DIR=./.data/chroma
CHROMA_COLLECTION=localcowork
EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBED_DEVICE=cpu

# =============================================================
# MCP Servers
# =============================================================
# Filesystem sandbox — agent can only touch files under this path
FILESYSTEM_SANDBOX_DIR=~/Documents
# Document processing output dir
DOCUMENT_OUTPUT_DIR=./.data/documents
# Audit log path
AUDIT_LOG_PATH=./.data/audit/tool_calls.jsonl

# =============================================================
# Agent
# =============================================================
# Max tool calls per conversation turn
MAX_TOOL_CALLS=10
# Tool call timeout in seconds
TOOL_TIMEOUT=30
