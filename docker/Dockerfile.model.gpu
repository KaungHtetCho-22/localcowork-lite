# --- Stage 1: Builder ---
FROM nvidia/cuda:12.1.0-devel-ubuntu22.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl cmake git build-essential \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN git clone https://github.com/ggerganov/llama.cpp /llama.cpp && \
    cd /llama.cpp && \
    cmake -B build \
      -DGGML_CUDA=ON \
      -DGGML_CUDA_NO_VMM=ON \
      -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build --config Release -j2

# --- Stage 2: Runtime ---
FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    libgomp1 curl libssl3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /llama.cpp/build/bin/llama-server /usr/local/bin/
COPY --from=builder /llama.cpp/build/bin/*.so* /usr/local/lib/
RUN ldconfig

RUN mkdir -p /root/.cache/huggingface

EXPOSE 8080

CMD ["llama-server", \
     "-hf", "Qwen/Qwen2.5-7B-Instruct-GGUF:Q4_K_M", \
     "--port", "8080", \
     "--host", "0.0.0.0", \
     "--ctx-size", "8192", \
     "--n-gpu-layers", "35", \
     "--flash-attn", "on", \
     "--temp", "0.1", \
     "--top-p", "0.1", \
     "--repeat-penalty", "1.1", \
     "--verbose"]